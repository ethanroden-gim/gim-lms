rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.isAdmin == true;
    }

    function isManager() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.isManager == true;
    }

    function canClaimPendingUser(userId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(userId))
        && userDoc(userId).data.needsFirstLogin == true
        && userDoc(userId).data.email == request.auth.token.email;
    }

    // Users - anyone signed in can read. Admins can create/update any user,
    // including pre-login pending_* users. Learners can only update basic
    // profile fields on their own record.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (uid == request.auth.uid || isAdmin());
      allow update: if isAdmin()
        || (
          request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name',
            'photoURL',
            'lastSignInAt',
            'email',
            'emailLower'
          ])
        );
      allow delete: if isAdmin() || canClaimPendingUser(uid);
    }

    // Courses, assessments, departments, roles, settings - admins write, signed-in users read.
    match /courses/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /assessments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /departments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Enrollments - learners read/update their own progress. Admins/managers
    // read all and can assign/update. Only admins can delete/unassign.
    match /enrollments/{id} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || canClaimPendingUser(resource.data.userId) || isAdmin() || isManager());
      allow create: if isAdmin()
        || isManager()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        || isManager()
        || (
          canClaimPendingUser(resource.data.userId)
          && request.resource.data.userId == request.auth.uid
        )
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
        );
      allow delete: if isAdmin() || canClaimPendingUser(resource.data.userId);
    }

    // Activity - learners write/read their own, admins read all.
    match /activity/{id} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || canClaimPendingUser(resource.data.userId) || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (
          canClaimPendingUser(resource.data.userId)
          && request.resource.data.userId == request.auth.uid
        );
      allow delete: if isAdmin();
    }

    // Admin audit log.
    match /adminActivity/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // Attempts - learners create their own attempts. Admins need read/update
    // access for grading, including failed graded attempts.
    match /attempts/{id} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || canClaimPendingUser(resource.data.userId) || isAdmin() || isManager());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (
          canClaimPendingUser(resource.data.userId)
          && request.resource.data.userId == request.auth.uid
        );
      allow delete: if isAdmin();
    }
  }
}
