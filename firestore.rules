rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.isAdmin == true;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && (userId == request.auth.uid || isAdmin());
      allow update: if signedIn() && (userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /courses/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /enrollments/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin()
        || (signedIn() && request.resource.data.userId == request.auth.uid)
        || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /assessments/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /attempts/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /activity/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /adminActivity/{id} {
      allow read, create, update, delete: if isAdmin();
    }

    match /departments/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
